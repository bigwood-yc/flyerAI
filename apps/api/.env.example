# Supabase credentials — get from: Dashboard → Settings → API Keys
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<secret_key>   # "Secret key" on the API Keys page

# Beta mode: true = only whitelisted users can access; false = open registration
BETA_MODE=true

# Existing variables (keep these)
ANTHROPIC_API_KEY=<your_anthropic_key>
FLIPP_DB_PATH=/path/to/flipp_cache.db
